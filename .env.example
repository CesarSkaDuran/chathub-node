# Servidor
PORT=3000
NODE_ENV=development

# JWT
# Genera un secreto fuerte y unico, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NUNCA uses este valor de ejemplo en produccion.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# MySQL (WAMP - sin password por defecto)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=chathub
DB_USER=root
DB_PASSWORD=

# CORS - URL(s) del frontend permitidas (separadas por coma)
CORS_ORIGIN=http://localhost:4200
